# EditorConfig helps IDEs keep non-C++ files aligned with repository style.
root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
insert_final_newline = true
trim_trailing_whitespace = true

[*.{c,cc,cpp,cxx,h,hh,hpp,hxx}]
indent_size = 4

[{CMakeLists.txt,*.cmake}]
indent_size = 4

[*.{json,jsonc}]
indent_size = 4

[*.{yml,yaml}]
indent_size = 2

[.clang*]
indent_size = 2

[*.md]
indent_size = 2
trim_trailing_whitespace = false

[*.sh]
indent_size = 4

[*.{bat,cmd,ps1}]
end_of_line = crlf
indent_size = 4

[{Makefile,*.mk}]
indent_style = tab
